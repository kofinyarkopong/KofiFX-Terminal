# KofiFX Terminal — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values.
# The terminal works without any keys — yfinance is the default fallback.

# ── OANDA Practice API (free) ─────────────────────────────────────────────
# Get a free practice account at https://www.oanda.com/register/
# Then: My Account -> Manage API Access -> Generate Token
#
# When OANDA_API_KEY is set, all forex pairs and gold/silver (XAUUSD/XAGUSD)
# are sourced from OANDA with real market data. Indices (US100, SP500, GER40,
# DXY) continue to use yfinance since OANDA does not carry them.
#
OANDA_API_KEY=
# OANDA_ACCOUNT_ID=  # optional, only needed for order placement (future use)
# OANDA_BASE_URL=https://api-fxpractice.oanda.com/v3  # default: practice server
# For a live account change to: https://api-fxtrade.oanda.com/v3

# ── Flask ──────────────────────────────────────────────────────────────────
# PORT=5001          # default port, change if 5001 is already in use
# FLASK_DEBUG=0      # set to 1 to enable Flask debug mode (not for production)
